# FillMyPDF Environment Configuration
# =====================================

# App Settings
APP_NAME=FillMyPDF
APP_VERSION=4.0.0
DEBUG=False

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Security - CHANGE THIS IN PRODUCTION!
PROFILES_ENCRYPTION_KEY=change-this-to-a-strong-random-key-in-production

# Profile Settings
PROFILES_ENCRYPTION_ENABLED=True
PROFILES_FREE_LIMIT=1
PROFILES_PRO_LIMIT=-1

# AI Defaults — used when AI_PROVIDER=gemini (can be overridden per request)
DEFAULT_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
DEFAULT_AI_MODEL=gemini-2.5-flash
DEFAULT_DPI=200

# ── LLM Provider toggle ────────────────────────────────────────────────────
# AI_PROVIDER: "gemini" (default) = cloud Gemini API
#              "local"            = self-hosted Ollama/vLLM (no API key needed)
AI_PROVIDER=gemini

# Local / on-prem server — Ollama default port is 11434.
# For HIPAA: run Ollama on the same host or on a private-network GPU box.
#   Install:  brew install ollama
#   Pull:     ollama pull qwen2.5:3b-instruct   (8 GB Mac)
#             ollama pull qwen2.5:7b-instruct   (if you have 16 GB+)
#   Serve:    ollama serve   (starts on port 11434)
LOCAL_AI_BASE_URL=http://localhost:11434/v1
LOCAL_AI_MODEL=qwen2.5:3b-instruct
LOCAL_AI_API_KEY=ollama

# Hard HIPAA guardrail — when True, any request whose resolved base_url
# points to an external (non-loopback, non-RFC-1918) host is rejected.
# Set to True in production HIPAA deployments.
AI_LOCAL_ONLY=False

# Opt-in coordinate-context in the LLM prompt (off by default).
# When True, each field's page/x-band/y-band is included in the prompt
# to help the LLM disambiguate fields with identical labels (e.g. two "Phone"
# boxes in different form sections).  A/B-test before enabling permanently.
AI_USE_COORDINATES=False

# CommonForms Settings
COMMONFORMS_MODEL=FFDNet-S
COMMONFORMS_CONFIDENCE=0.1
COMMONFORMS_IMAGE_SIZE=1024

# Stripe Billing (optional — enables /api/v1/billing/checkout and /portal)
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook secret from https://dashboard.stripe.com/webhooks
# Point the webhook to POST /api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=

# Email / SMTP (optional — enables signing notifications)
# Leave SMTP_HOST blank to disable email entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@fillmypdf.app
SMTP_FROM_NAME=FillMyPDF
SMTP_USE_TLS=True
# Public URL shown in email links (set to your production domain)
APP_BASE_URL=http://localhost:8000
